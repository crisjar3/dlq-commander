{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "electron.vite.config.*",
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/shared/**/*.ts",
    "tests/unit/**/*.ts",
    "tests/e2e/**/*.ts",
    "tests/e2e-brokers/**/*.ts",
    "tests/integration/**/*.ts",
    "vitest.config.ts",
    "vitest.integration.config.ts",
    "playwright.config.ts",
    "playwright.brokers.config.ts"
  ],
  "exclude": ["tests/unit/resource-explorer-list.test.ts"],
  "compilerOptions": {
    "composite": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["src/shared/*"],
      "@main/*": ["src/main/*"]
    },
    "types": ["node"]
  }
}
