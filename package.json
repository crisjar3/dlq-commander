{
  "name": "dlq-commander",
  "version": "0.1.0",
  "description": "Desktop operations console for dead-letter queues across message brokers",
  "main": "./out/main/index.js",
  "author": "DLQCommander contributors",
  "license": "MIT",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.0.0 <23",
    "pnpm": "11.9.0"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "pnpm typecheck && electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "pnpm build && playwright test",
    "test:e2e:brokers": "pnpm build && playwright test --config playwright.brokers.config.ts",
    "lab:up": "docker compose up -d --wait",
    "lab:seed": "node scripts/seed-rabbitmq.mjs && node scripts/seed-kafka.mjs",
    "lab:down": "docker compose down",
    "package": "pnpm build && electron-builder --dir",
    "dist": "pnpm build && electron-builder",
    "postinstall": "electron --version"
  },
  "dependencies": {
    "@azure/service-bus": "^7.9.5",
    "@tanstack/react-query": "^5.66.8",
    "@tanstack/react-table": "^8.21.2",
    "@tanstack/react-virtual": "^3.13.2",
    "amqplib": "^0.10.5",
    "electron-log": "^5.2.4",
    "kafkajs": "^2.2.4",
    "lucide-react": "^0.475.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@playwright/test": "^1.50.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/amqplib": "^0.10.7",
    "@types/node": "^22.13.4",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^43.1.1",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "eslint": "^9.20.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.15.0",
    "jsdom": "^26.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.0",
    "vite": "^6.1.0",
    "vitest": "^3.0.5"
  },
  "build": {
    "appId": "com.dlqcommander.desktop",
    "productName": "DLQCommander",
    "asar": true,
    "files": [
      "out/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": ["nsis"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
